{
  "name": "@jowork/core",
  "version": "0.1.0",
  "description": "Jowork core — open-source AI work partner platform",
  "type": "module",
  "license": "AGPL-3.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": "./dist/*"
  },
  "bin": {
    "jowork": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/locales dist/ && node ../../scripts/build-i18n.js",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "ali-oss": "^6.23.0",
    "better-sqlite3": "^12.6.2",
    "bonjour-service": "^1.2.1",
    "express": "^5.0.1",
    "gpt-tokenizer": "^3.4.0",
    "imapflow": "^1.2.10",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.3",
    "node-pty": "^1.1.0",
    "stripe": "^17.7.0",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/express-serve-static-core": "*",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.3.2",
    "@types/ws": "^8.5.14",
    "typescript": "^5.9.3"
  }
}
