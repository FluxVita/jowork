  "productName": "FluxVita",
  "identifier": "com.fluxvita.gateway",
  "version": "0.1.1",
  "build": {
    "frontendDist": "../tauri-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
