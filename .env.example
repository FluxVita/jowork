# Jowork Gateway — 环境变量模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# ── 服务配置 ─────────────────────────────────────────────────────────────────
GATEWAY_PORT=18800
# 兼容变量：若未设置 GATEWAY_PORT，会回退读取 JOWORK_PORT
# JOWORK_PORT=18800
GATEWAY_HOST=0.0.0.0

# 公网访问地址（用于 OAuth 回调等需要完整 URL 的场景）
# GATEWAY_PUBLIC_URL=https://your-domain.com

# JWT 密钥（生产环境请生成随机字符串）
JWT_SECRET=change-me-to-a-random-secret

# 数据库路径
DB_PATH=./data/datamap.db

# 缓存目录
CACHE_DIR=./cache

# 日志级别 (debug|info|warn|error)
LOG_LEVEL=info

# ── 品牌配置 ─────────────────────────────────────────────────────────────────
# 组织名称（用于欢迎消息等）
ORG_NAME=My Organization
# localStorage token key 名（默认 jowork_token，企业内部版可按需自定义）
# TOKEN_STORAGE_KEY=jowork_token

# ── 飞书（Lark/Feishu）— 可选 ─────────────────────────────────────────────────
# 不使用飞书时，保持为空即可
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_OPEN_ID=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
# 飞书租户域名，用于生成 Wiki 外链
# FEISHU_TENANT_DOMAIN=your-org.feishu.cn

# ── GitLab — 可选 ─────────────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=
# GitLab OAuth（推荐；可替代手动 Token）
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
# 兼容旧命名（可选）
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_WEBHOOK_SECRET=

# ── GitHub — 可选（开源版通用 Connector）──────────────────────────────────────
# OAuth（推荐）
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# 兜底模式（无 OAuth 时可用）
GITHUB_TOKEN=
GITHUB_REPOS=

# ── Notion — 可选（开源版通用 Connector）──────────────────────────────────────
# OAuth（推荐）
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# 兜底模式（无 OAuth 时可用）
# NOTION_TOKEN=
# 逗号分隔的数据库 ID（可选，空则自动发现所有可访问数据库）
# NOTION_DATABASE_IDS=

# ── Slack / Discord — OAuth（可选）───────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── Google / Microsoft — OAuth（可选）────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ── Atlassian（Jira / Confluence）— OAuth（可选）────────────────────────────
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# Atlassian Cloud Site ID（OAuth 后 discover/fetch 需要）
ATLASSIAN_CLOUD_ID=

# ── Telegram — 可选（开源版通用 Channel）─────────────────────────────────────
# 从 @BotFather 获取的 Bot Token
TELEGRAM_BOT_TOKEN=
# 接收模式：polling（本地开发）或 webhook（生产）
# TELEGRAM_MODE=polling
# Webhook 完整 URL（webhook 模式时填入）
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/channels/telegram/webhook

# ── PostHog — 可选 ────────────────────────────────────────────────────────────
POSTHOG_API_KEY=
# PostHog 项目 ID（在 Project Settings 中查看）
POSTHOG_PROJECT_ID=
# PostHog API 地址（默认 https://us.posthog.com/api，EU 用户改为 https://eu.posthog.com/api）
# POSTHOG_API_HOST=https://us.posthog.com/api

# ── 阿里云 OSS — 可选 ─────────────────────────────────────────────────────────
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=

# ── 邮箱（IMAP）— 可选 ────────────────────────────────────────────────────────
EMAIL_HOST=imap.example.com
EMAIL_PORT=993
EMAIL_USER=
EMAIL_PASS=

# ── AI 模型 ───────────────────────────────────────────────────────────────────
# Klaude（基于 Anthropic Claude 的本地服务）
# KLAUDE_API_KEY=not-needed
# KLAUDE_PORT=8899

# Moonshot（备用模型，可选）
MOONSHOT_API_KEY=

# Linear（可选）
LINEAR_API_KEY=

# 模型预算（美元/天）
MODEL_DAILY_BUDGET=10
MODEL_USER_DAILY_BUDGET=3
MODEL_MAX_TOKENS=4096

# ── 告警接收人（Premium 功能）─────────────────────────────────────────────────
# 接收系统告警的飞书用户 Open ID
# ALERT_RECEIVER_OPEN_ID=

# ── Tailscale（可选，用于内网访问）──────────────────────────────────────────────
TAILSCALE_ENABLED=false

# ── Klaude 认证代理（Premium 功能）─────────────────────────────────────────────
# 启用后 Gateway 在 KLAUDE_PROXY_PORT 额外监听，团队成员通过代理访问 Klaude
KLAUDE_PROXY_ENABLED=false
KLAUDE_PROXY_PORT=8899
KLAUDE_URL=http://127.0.0.1:8900
KLAUDE_GATEWAY_SECRET=
