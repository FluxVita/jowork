# Jowork — environment variables template
# Copy to .env and fill in your values.
# All variables are optional — sensible defaults are used when unset.

# ─── Server ──────────────────────────────────────────────────────────────────
# Gateway HTTP port (default: 18800)
PORT=18800

# Deployment mode: "personal" (no login, local only) or "team" (multi-user)
JOWORK_MODE=personal

# ─── Security ────────────────────────────────────────────────────────────────
# JWT signing secret — MUST be changed in production (team mode)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production

# ─── Storage ─────────────────────────────────────────────────────────────────
# Data directory (default: OS standard path — ~/Library/Application Support/Jowork on macOS)
# JOWORK_DATA_DIR=/path/to/custom/data/dir

# ─── AI Models ───────────────────────────────────────────────────────────────
# Anthropic API key (required for Claude models)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: fallback model provider
MOONSHOT_API_KEY=
OPENAI_API_KEY=

# ─── Premium (optional) ──────────────────────────────────────────────────────
# License key for Jowork Premium features
# Leave empty to use Free tier
JOWORK_LICENSE_KEY=

# ─── Logging ─────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
NODE_ENV=production
