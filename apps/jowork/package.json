{
  "name": "@jowork/app",
  "version": "0.1.0",
  "description": "Jowork — open-source desktop app (Tauri + Vue 3 CDN)",
  "license": "AGPL-3.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "echo 'no tests yet'",
    "start": "node dist/index.js",
    "start:cluster": "node dist/cluster.js",
    "dev": "node --watch dist/index.js",
    "build:sidecar": "../../scripts/build-sidecar.sh",
    "tauri:dev": "npx @tauri-apps/cli dev",
    "tauri:build": "npm run build:sidecar && npx @tauri-apps/cli build"
  },
  "dependencies": {
    "@jowork/core": "workspace:*",
    "express": "^5.0.0",
    "serve-static": "^2.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/serve-static": "^1.15.0",
    "typescript": "^5.4.0"
  }
}
